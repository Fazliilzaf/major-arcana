OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Brand (prompts + knowledge folder)
ARCANA_BRAND=hair-tp-clinic

# Optional (recommended in production behind reverse proxy / Vercel / Nginx)
TRUST_PROXY=false

# CORS policy
# Strict-default i alla miljöer (om CORS_* inte sätts explicit).
# Example:
# CORS_ALLOWED_ORIGINS=https://arcana.hairtpclinic.se,https://arcana-staging.onrender.com,https://hairtpclinic.se,https://www.hairtpclinic.se
CORS_STRICT=true
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_NO_ORIGIN=false
CORS_ALLOW_CREDENTIALS=false

# Optional: multi-domain mapping (host -> brand)
# Example:
# ARCANA_BRAND_BY_HOST='{"arcana.hairtpclinic.se":"hair-tp-clinic","arcana-staging.onrender.com":"hair-tp-clinic","hairtpclinic.se":"hair-tp-clinic","www.hairtpclinic.se":"hair-tp-clinic","curatiio.se":"curatiio","www.curatiio.se":"curatiio"}'
ARCANA_BRAND_BY_HOST=

# Optional: map incoming clinic IDs to tenant IDs for public web payloads
# Example:
# ARCANA_PUBLIC_CLINIC_ALIASES='{"hair-to-clinic":"hair-tp-clinic","goteborg":"hair-goteborg"}'
ARCANA_PUBLIC_CLINIC_ALIASES=

# Persistent driftdata-root (Render disk: /var/data/arcana)
# Alla store-paths nedan använder denna root om deras specifika env saknas.
ARCANA_STATE_ROOT=./data

# Memory
MEMORY_STORE_PATH=./data/memory.json
MEMORY_TTL_DAYS=30

# Auth / RBAC foundation (Pilot 0.1)
AUTH_STORE_PATH=./data/auth.json
AUTH_SESSION_TTL_HOURS=12
AUTH_SESSION_IDLE_MINUTES=180
AUTH_LOGIN_TICKET_TTL_MINUTES=10
AUTH_AUDIT_MAX_ENTRIES=5000
# Rekommenderat: true för append-only auditkedja med checksummer
# Sätt till false endast om du uttryckligen vill tillåta trunkering till AUTH_AUDIT_MAX_ENTRIES.
AUTH_AUDIT_APPEND_ONLY=true
AUTH_LOGIN_RATE_LIMIT_WINDOW_SEC=60
AUTH_LOGIN_RATE_LIMIT_MAX=20
AUTH_SELECT_TENANT_RATE_LIMIT_MAX=30
# Om true kan OWNER-login själv-läka lösenordsdrift genom att återställa till ARCANA_OWNER_PASSWORD
# när korrekt OWNER-email+lösenord anges.
AUTH_OWNER_CREDENTIAL_SELF_HEAL=true
# Session-rotation vid inloggning: none | tenant | user
AUTH_LOGIN_SESSION_ROTATION=tenant
# Distributed runtime backend: memory | redis
ARCANA_DISTRIBUTED_BACKEND=memory
ARCANA_REDIS_URL=
ARCANA_REDIS_REQUIRED=false
ARCANA_REDIS_CONNECT_TIMEOUT_MS=4000
ARCANA_REDIS_KEY_PREFIX=arcana
ARCANA_GATEWAY_QUEUE_LOCK_TTL_MS=30000
ARCANA_GATEWAY_QUEUE_ACQUIRE_TIMEOUT_MS=10000
ARCANA_GATEWAY_QUEUE_POLL_INTERVAL_MS=80
# Microsoft Graph read-only inbox ingest (AnalyzeInbox)
ARCANA_GRAPH_READ_ENABLED=false
ARCANA_GRAPH_TENANT_ID=
ARCANA_GRAPH_CLIENT_ID=
ARCANA_GRAPH_CLIENT_SECRET=
ARCANA_GRAPH_USER_ID=
ARCANA_GRAPH_FULL_TENANT=false
ARCANA_GRAPH_USER_SCOPE=single
# Allowlist-läge för read ingest (Inbox + SentItems), t.ex. info@...,bokning@...,fazli@...
ARCANA_MAILBOX_ALLOWLIST=
# Full-tenant urval: index i /users-listning (1-baserat), t.ex. 1,2,3,5,8
ARCANA_GRAPH_MAILBOX_INDEXES=
# Full-tenant urval: explicita mailboxId/UPN (komma-separerat), t.ex. kons@hairtpclinic.com
ARCANA_GRAPH_MAILBOX_IDS=
ARCANA_GRAPH_MAX_USERS=50
ARCANA_GRAPH_MAX_MESSAGES_PER_USER=50
ARCANA_GRAPH_MAX_INBOX_MESSAGES_PER_USER=25
ARCANA_GRAPH_MAX_SENT_MESSAGES_PER_USER=25
ARCANA_GRAPH_MAILBOX_TIMEOUT_MS=5000
ARCANA_GRAPH_RUN_TIMEOUT_MS=30000
ARCANA_GRAPH_MAX_MAILBOX_ERRORS=5
ARCANA_GRAPH_REQUEST_MAX_RETRIES=2
ARCANA_GRAPH_RETRY_BASE_DELAY_MS=500
ARCANA_GRAPH_RETRY_MAX_DELAY_MS=5000
ARCANA_GRAPH_PAGINATION_MAX_PAGES=200
ARCANA_GRAPH_WINDOW_DAYS=14
ARCANA_GRAPH_MAX_MESSAGES=100
ARCANA_GRAPH_MAX_INBOX_MESSAGES=50
ARCANA_GRAPH_MAX_SENT_MESSAGES=50
ARCANA_GRAPH_INCLUDE_READ=false
ARCANA_GRAPH_AUTHORITY_HOST=https://login.microsoftonline.com
ARCANA_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
ARCANA_GRAPH_SCOPE=https://graph.microsoft.com/.default
ARCANA_GRAPH_SEND_ENABLED=false
ARCANA_GRAPH_SEND_ALLOWLIST=
ARCANA_GRAPH_SEND_TIMEOUT_MS=8000

ARCANA_API_RATE_LIMIT_WINDOW_SEC=60
ARCANA_API_RATE_LIMIT_READ_MAX=300
ARCANA_API_RATE_LIMIT_WRITE_MAX=120
ARCANA_RISK_RATE_LIMIT_MAX=120
ARCANA_ORCHESTRATOR_RATE_LIMIT_MAX=80
ARCANA_PUBLIC_RATE_LIMIT_WINDOW_SEC=60
ARCANA_PUBLIC_CLINIC_RATE_LIMIT_MAX=180
ARCANA_PUBLIC_CHAT_RATE_LIMIT_MAX=90
ARCANA_SEMANTIC_MODEL_MODE=heuristic
ARCANA_PUBLIC_CHAT_BETA_ENABLED=false
ARCANA_PUBLIC_CHAT_BETA_HEADER=x-arcana-beta-key
ARCANA_PUBLIC_CHAT_BETA_KEY=
ARCANA_PUBLIC_CHAT_BETA_ALLOW_HOSTS=
ARCANA_PUBLIC_CHAT_BETA_ALLOW_LOCALHOST=true
ARCANA_PUBLIC_CHAT_BETA_DENY_MESSAGE=Den här chatten är i begränsad beta. Kontakta kliniken för åtkomst.
ARCANA_PUBLIC_CHAT_KILL_SWITCH=false
ARCANA_PUBLIC_CHAT_KILL_SWITCH_MESSAGE=Patientchatten är tillfälligt pausad. Kontakta kliniken via telefon eller e-post.
ARCANA_PUBLIC_CHAT_MAX_TURNS=12
ARCANA_PUBLIC_CHAT_PROMPT_INJECTION_FILTER_ENABLED=true
ARCANA_PUBLIC_CHAT_PROMPT_INJECTION_MESSAGE=Jag kan inte hjälpa till med den typen av instruktion. Kontakta kliniken direkt för fortsatt hjälp.
ARCANA_RISK_DUAL_SIGNOFF_REQUIRED=false
ARCANA_DEFAULT_TENANT=hair-tp-clinic

# Readiness guard (preflight)
ARCANA_PREFLIGHT_READINESS_CHECKS=owner_mfa_enforced,cors_strict
ARCANA_PREFLIGHT_READINESS_USE_REQUIRED_CHECKS=false
ARCANA_PREFLIGHT_READINESS_FAIL_STATUSES=red
ARCANA_PREFLIGHT_READINESS_ALLOW_MISSING=false
ARCANA_PREFLIGHT_READINESS_SHOW_OWNER_MFA_GAPS=true
ARCANA_PREFLIGHT_READINESS_CORS_RUNTIME_PROBE=true
ARCANA_PREFLIGHT_READINESS_CORS_PROBE_PATH=/healthz
ARCANA_PREFLIGHT_READINESS_REPORT_FILE=
ARCANA_PREFLIGHT_VERIFY_REQUIRED_CHECKS=true
ARCANA_PREFLIGHT_HEALABLE_GUARD_CHECKS=owner_mfa_enforced
ARCANA_PREFLIGHT_FORCE_OPS_ON_GUARD_FAIL=false
ARCANA_PREFLIGHT_REPORT_FILE=
ARCANA_PUBLIC_PILOT_PREFLIGHT_REPORT_FILE=./data/reports/preflight-public-latest.json

# Bootstrap first OWNER user (required to log in to /api/v1)
ARCANA_OWNER_EMAIL=
ARCANA_OWNER_PASSWORD=
ARCANA_AUTH_OWNER_MFA_BYPASS_HOSTS=arcana-staging.onrender.com,arcana.hairtpclinic.se
# One-shot recovery flags (set true only during controlled recovery deploy)
ARCANA_BOOTSTRAP_RESET_OWNER_PASSWORD=false
ARCANA_BOOTSTRAP_RESET_OWNER_MFA=false

# Scheduler / Automation
ARCANA_REPORTS_DIR=./data/reports
ARCANA_REPORT_RETENTION_MAX_FILES=60
ARCANA_REPORT_RETENTION_MAX_AGE_DAYS=45
ARCANA_SCHEDULER_ENABLED=true
ARCANA_SCHEDULER_REPORT_WINDOW_DAYS=14
ARCANA_SCHEDULER_REPORT_INTERVAL_HOURS=24
ARCANA_SCHEDULER_BACKUP_INTERVAL_HOURS=24
ARCANA_SCHEDULER_RESTORE_DRILL_INTERVAL_HOURS=168
ARCANA_SCHEDULER_RESTORE_DRILL_FULL_INTERVAL_HOURS=720
ARCANA_SCHEDULER_AUDIT_INTEGRITY_INTERVAL_HOURS=24
ARCANA_SCHEDULER_SECRET_ROTATION_INTERVAL_HOURS=24
ARCANA_SCHEDULER_RELEASE_GOVERNANCE_INTERVAL_HOURS=24
ARCANA_SCHEDULER_RELEASE_GOVERNANCE_AUTO_REVIEW_ENABLED=true
ARCANA_SCHEDULER_SECRET_ROTATION_DRY_RUN=true
ARCANA_SCHEDULER_SECRET_ROTATION_NOTE=Scheduled secret rotation snapshot
ARCANA_SCHEDULER_ALERT_PROBE_INTERVAL_MINUTES=15
ARCANA_SCHEDULER_STRATEGIC_WEEKLY_INTERVAL_HOURS=168
ARCANA_SCHEDULER_STRATEGIC_MONTHLY_INTERVAL_HOURS=720
ARCANA_SCHEDULER_STRATEGIC_FORWARD_INTERVAL_HOURS=24
ARCANA_SCHEDULER_INCIDENT_AUTO_ESCALATION_ENABLED=true
ARCANA_SCHEDULER_INCIDENT_AUTO_ESCALATION_LIMIT=25
ARCANA_SCHEDULER_INCIDENT_AUTO_ASSIGN_OWNER_ENABLED=true
ARCANA_SCHEDULER_INCIDENT_AUTO_ASSIGN_OWNER_LIMIT=100
ARCANA_SCHEDULER_SLO_AUTO_TICKETING_ENABLED=true
ARCANA_SCHEDULER_SLO_TICKET_MAX_PER_RUN=8
ARCANA_ALERT_WEBHOOK_URL=
ARCANA_ALERT_WEBHOOK_SECRET=
ARCANA_ALERT_WEBHOOK_TIMEOUT_MS=4000
ARCANA_SECRET_ROTATION_STORE_PATH=./data/secret-rotation.json
ARCANA_SECRET_ROTATION_MAX_AGE_DAYS=90
ARCANA_SLO_TICKET_STORE_PATH=./data/slo-tickets.json
ARCANA_SLO_TICKET_STORE_MAX_ENTRIES=3000
ARCANA_CAPABILITY_ANALYSIS_STORE_PATH=./data/capability-analysis.json
ARCANA_CAPABILITY_ANALYSIS_MAX_ENTRIES=15000
ARCANA_RELEASE_GOVERNANCE_STORE_PATH=./data/release-governance.json
ARCANA_RELEASE_GOVERNANCE_MAX_CYCLES=400
ARCANA_RELEASE_NO_GO_FREE_DAYS=14
ARCANA_RELEASE_REQUIRE_DISTINCT_SIGNOFF_USERS=true
ARCANA_RELEASE_REQUIRE_PENTEST_EVIDENCE=false
ARCANA_RELEASE_PENTEST_MAX_AGE_DAYS=120
ARCANA_RELEASE_POST_LAUNCH_REVIEW_WINDOW_DAYS=30
ARCANA_RELEASE_POST_LAUNCH_STABILIZATION_DAYS=14
ARCANA_RELEASE_ENFORCE_POST_LAUNCH_STABILIZATION=false
ARCANA_RELEASE_REALITY_AUDIT_INTERVAL_DAYS=90
ARCANA_RELEASE_REQUIRE_FINAL_LIVE_SIGNOFF=false
ARCANA_RELEASE_CYCLE_ENSURE_STAFF=true
ARCANA_RELEASE_RISK_EMAIL=
ARCANA_RELEASE_RISK_PASSWORD=
ARCANA_RELEASE_OPS_EMAIL=
ARCANA_RELEASE_OPS_PASSWORD=
ARCANA_RELEASE_CYCLE_NOTE=Automated release cycle
ARCANA_RELEASE_EVIDENCE_SOURCE=release_cycle_script
ARCANA_RELEASE_AUTO_LAUNCH=false
ARCANA_RELEASE_LAUNCH_STRATEGY=tenant_batch
ARCANA_RELEASE_LAUNCH_BATCH_LABEL=batch-1
ARCANA_RELEASE_LAUNCH_ROLLBACK_PLAN=Rollback within 10 minutes on critical signal.
ARCANA_RELEASE_REVIEW_NOW=false
ARCANA_RELEASE_REVIEW_STATUS=ok
ARCANA_RELEASE_REVIEW_NOTE=Automated release review
ARCANA_RELEASE_REALITY_AUDIT_NOW=false
ARCANA_RELEASE_CHANGE_GOVERNANCE_VERSION=
ARCANA_RELEASE_REALITY_AUDIT_NOTE=Automated quarterly reality audit marker
ARCANA_RELEASE_FINAL_LIVE_SIGNOFF_NOW=false
ARCANA_RELEASE_FINAL_LIVE_SIGNOFF_NOTE=Final live sign-off after stabilized launch window.
ARCANA_RELEASE_FAIL_ON_GATE=false
ARCANA_RELEASE_REUSE_LATEST_CYCLE=false
ARCANA_RELEASE_CYCLE_ID=
ARCANA_RELEASE_CYCLE_OUT_FILE=./data/reports/release-cycle-latest.json
ARCANA_STABILITY_WINDOW_DAYS=14
ARCANA_STABILITY_WINDOW_HISTORY_LIMIT=200
ARCANA_STABILITY_WINDOW_CYCLE_ID=
ARCANA_STABILITY_WINDOW_RUN_REQUIRED_SUITE=false
ARCANA_STABILITY_WINDOW_REQUIRE_COMPLETE=false
ARCANA_STABILITY_WINDOW_FAIL_ON_WINDOW=false
ARCANA_STABILITY_WINDOW_FAIL_ON_RELEASE_BLOCKERS=false
ARCANA_STABILITY_WINDOW_JSON=false
ARCANA_STABILITY_WINDOW_OUT_FILE=./data/reports/stability-window-latest.json
ARCANA_FINALIZATION_SWEEP_WITH_LOCAL_SERVER=false
ARCANA_FINALIZATION_SWEEP_BOOTSTRAP_RELEASE_CYCLE=false
ARCANA_FINALIZATION_SWEEP_BOOTSTRAP_MODE=if_missing
ARCANA_FINALIZATION_SWEEP_STRICT=false
ARCANA_FINALIZATION_SWEEP_OUT_FILE=./data/reports/finalization-sweep-latest.json
ARCANA_FINALIZATION_SWEEP_JSON=false
ARCANA_FINALIZATION_SWEEP_REPORT_FILE=./data/reports/finalization-sweep-latest.json
ARCANA_EXPECTED_EXTERNAL_FAIL_STEPS=check_pentest_evidence,report_release_readiness,report_stability_window,release_go_live_gate
ARCANA_CLOSURE_STATUS_EXPECTED_REMAINING=external_pentest_evidence,stability_window_14_30d,formal_live_signoff
ARCANA_CLOSURE_STATUS_REPORT_FILE=./data/reports/closure-status-latest.json
ARCANA_CLOSURE_GUARD_STRICT_EXPECTED_ONLY=true
ARCANA_CLOSURE_GUARD_REQUIRE_DONE=false
ARCANA_PENTEST_EVIDENCE_OUT_FILE=./docs/security/pentest-latest.md
ARCANA_PENTEST_VENDOR=
ARCANA_PENTEST_SCOPE_DATE=
ARCANA_PENTEST_REPORT_DATE=
ARCANA_PENTEST_SCOPE=API, auth, tenant isolation, patient channel
ARCANA_PENTEST_SEVERITY_CRITICAL=0
ARCANA_PENTEST_SEVERITY_HIGH=0
ARCANA_PENTEST_SEVERITY_MEDIUM=0
ARCANA_PENTEST_SEVERITY_LOW=0
ARCANA_PENTEST_FIXES_COMPLETED=
ARCANA_PENTEST_RESIDUAL_RISK=
ARCANA_PENTEST_SIGNED_REFERENCE=
ARCANA_MONITOR_RESTORE_DRILL_MAX_AGE_DAYS=30
ARCANA_MONITOR_PILOT_REPORT_MAX_AGE_HOURS=36
ARCANA_METRICS_MAX_SAMPLES=5000
ARCANA_METRICS_SLOW_REQUEST_MS=1500
ARCANA_OBSERVABILITY_ALERT_MAX_ERROR_RATE_PCT=2.5
ARCANA_OBSERVABILITY_ALERT_MAX_P95_MS=1800
ARCANA_OBSERVABILITY_ALERT_MAX_SLOW_REQUESTS=25
ARCANA_SCHEDULER_STARTUP_DELAY_SEC=8
ARCANA_SCHEDULER_JITTER_SEC=4
ARCANA_SCHEDULER_RUN_ON_STARTUP=false

# Ops suite defaults
ARCANA_OPS_SUITE_FAIL_ON_NO_GO=false
ARCANA_OPS_SUITE_REMEDIATE_OUTPUT_GATES=false
ARCANA_OPS_SUITE_REMEDIATION_LIMIT=50
ARCANA_OPS_SUITE_REMEDIATE_OWNER_MFA_MEMBERSHIPS=false
ARCANA_OPS_SUITE_OWNER_MFA_REMEDIATION_LIMIT=50
ARCANA_OPS_SUITE_REFRESH_TENANT_ACCESS_CHECK=true
ARCANA_OPS_SUITE_CORS_RUNTIME_PROBE=true
ARCANA_OPS_SUITE_CORS_PROBE_PATH=/healthz
ARCANA_SCHEDULER_SUITE_OUT=

# Knowledge base
KNOWLEDGE_DIR=./knowledge/hair-tp-clinic

# Cliento booking widget
# One or more account IDs (comma-separated). If you provide two IDs the widget will let the user choose company.
CLIENTO_ACCOUNT_IDS=
# Optional fallback: open/iframe the public booking page (e.g. the Cliento "business" link)
CLIENTO_BOOKING_URL=
CLIENTO_WIDGET_SRC=https://cliento.com/widget-v2/cliento.js
CLIENTO_LOCALE=sv
CLIENTO_MERGE_LOCATIONS=false

# Brand-specific overrides (recommended if you serve both Hair TP Clinic + Curatiio from the same server)
CLIENTO_ACCOUNT_IDS_HAIR_TP_CLINIC=
CLIENTO_BOOKING_URL_HAIR_TP_CLINIC=https://cliento.com/business/hair-tp-clinic-1650/
CLIENTO_WIDGET_SRC_HAIR_TP_CLINIC=https://cliento.com/widget-v3/cliento.js

CLIENTO_ACCOUNT_IDS_CURATIIO=
CLIENTO_BOOKING_URL_CURATIIO=
CLIENTO_WIDGET_SRC_CURATIIO=https://cliento.com/widget-v2/cliento.js

KNOWLEDGE_DIR_HAIR_TP_CLINIC=./knowledge/hair-tp-clinic
KNOWLEDGE_DIR_CURATIIO=./knowledge/curatiio
