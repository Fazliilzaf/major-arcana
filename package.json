{
  "name": "arcana-",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "cco:live": "PORT=${PORT:-3000} ARCANA_GRAPH_READ_ENABLED=true ARCANA_GRAPH_SEND_ENABLED=true ARCANA_CCO_DELETE_ENABLED=true node server.js",
    "setup:mac": "bash ./scripts/bootstrap-mac-studio.sh",
    "workstation:bootstrap": "bash ./scripts/bootstrap-apple-workstation.sh",
    "workstation:bootstrap:remote": "bash ./scripts/bootstrap-remote-apple-client.sh",
    "commands:install": "bash ./scripts/install-arcana-commands.sh",
    "studio:sync": "bash ./scripts/mac-studio-sync.sh",
    "studio:share": "bash ./scripts/mac-studio-screen-share.sh",
    "studio:doctor": "bash ./scripts/mac-studio-doctor.sh",
    "studio:shell": "bash ./scripts/mac-studio-remote.sh shell",
    "studio:codex": "bash ./scripts/mac-studio-remote.sh codex",
    "studio:start": "bash ./scripts/mac-studio-start.sh",
    "imac:bootstrap": "bash ./scripts/imac-bootstrap.sh",
    "imac:sync": "bash ./scripts/imac-sync.sh",
    "imac:share": "bash ./scripts/imac-screen-share.sh",
    "imac:doctor": "bash ./scripts/imac-doctor.sh",
    "imac:codex:sync": "bash ./scripts/imac-codex-sync.sh",
    "imac:shell": "bash ./scripts/imac-remote.sh shell",
    "imac:codex": "bash ./scripts/imac-remote.sh codex",
    "imac:start": "bash ./scripts/imac-start.sh",
    "dev:offline": "PORT=${PORT:-3100} ARCANA_AI_PROVIDER=fallback ARCANA_GRAPH_READ_ENABLED=false ARCANA_GRAPH_SEND_ENABLED=false node server.js",
    "cco-next:sync-release": "bash ./scripts/sync-cco-next-release.sh",
    "check:syntax": "find ./src ./scripts ./public \\( -path \"./public/cco-next-release\" -o -path \"./public/cco-next-release/*\" \\) -prune -o -type f -name \"*.js\" -print0 | xargs -0 -n1 node --check && node --check server.js",
    "smoke": "bash ./scripts/smoke-template.sh",
    "smoke:local": "bash ./scripts/run-smoke-local.sh",
    "predeploy:quick": "bash ./scripts/predeploy-quick.sh",
    "smoke:public": "bash ./scripts/smoke-public.sh",
    "verify": "npm run check:syntax && npm run smoke:local",
    "backup:state": "node ./scripts/backup-state.js",
    "backup:list": "node ./scripts/list-backups.js",
    "backup:prune": "node ./scripts/prune-backups.js --dry-run",
    "backup:prune:apply": "node ./scripts/prune-backups.js --apply",
    "restore:state": "node ./scripts/restore-state.js",
    "ingest:mails": "node scripts/ingest-mails.js",
    "mail:seeds:preview": "bash ./scripts/apply-mail-seeds.sh --preview",
    "mail:seeds:apply": "bash ./scripts/apply-mail-seeds.sh --apply",
    "mail:seeds:apply-activate": "node ./scripts/apply-activate-mail-seeds.js --all --limit 50",
    "report:pilot": "bash ./scripts/save-pilot-report.sh",
    "report:release-readiness": "node ./scripts/report-release-readiness.js",
    "report:stability-window": "node ./scripts/report-stability-window.js",
    "report:stability-window:strict": "node ./scripts/report-stability-window.js --run-required-suite --require-complete-window --fail-on-window --fail-on-release-blockers",
    "check:pentest:evidence": "node ./scripts/check-pentest-evidence.js",
    "check:pentest:evidence:strict": "node ./scripts/check-pentest-evidence.js --strict",
    "pentest:evidence:upsert": "node ./scripts/upsert-pentest-evidence.js",
    "release:go-live:gate": "npm run report:release-readiness -- --require-pentest-evidence --strict && npm run report:stability-window:strict",
    "finalization:sweep": "node ./scripts/run-finalization-sweep.js",
    "finalization:sweep:local": "node ./scripts/run-finalization-sweep.js --with-local-server",
    "finalization:sweep:local:bootstrap": "node ./scripts/run-finalization-sweep.js --with-local-server --bootstrap-release-cycle",
    "finalization:sweep:local:bootstrap:fresh": "node ./scripts/run-finalization-sweep.js --with-local-server --bootstrap-release-cycle --bootstrap-mode always",
    "finalization:sweep:strict": "node ./scripts/run-finalization-sweep.js --strict",
    "finalization:sweep:strict:local": "node ./scripts/run-finalization-sweep.js --with-local-server --strict",
    "finalization:sweep:strict:local:bootstrap": "node ./scripts/run-finalization-sweep.js --with-local-server --bootstrap-release-cycle --strict",
    "finalization:sweep:strict:local:bootstrap:fresh": "node ./scripts/run-finalization-sweep.js --with-local-server --bootstrap-release-cycle --bootstrap-mode always --strict",
    "finalization:sweep:guard": "node ./scripts/check-finalization-sweep.js",
    "report:closure-status": "node ./scripts/report-closure-status.js",
    "report:closure-status:strict": "node ./scripts/report-closure-status.js --strict",
    "arcana:watch:once": "node ./scripts/arcana-watch-once.js",
    "closure:guard": "node ./scripts/check-closure-status.js",
    "closure:guard:done": "node ./scripts/check-closure-status.js --require-done",
    "release:cycle:auto": "node ./scripts/run-release-cycle.js",
    "release:cycle:auto:reuse": "node ./scripts/run-release-cycle.js --reuse-latest-cycle",
    "release:cycle:final-lock": "node ./scripts/run-release-cycle.js --reuse-latest-cycle --final-live-signoff-now",
    "pilot:evidence:check": "node ./scripts/check-pilot-evidence.js",
    "pilot:evidence:check:strict": "node ./scripts/check-pilot-evidence.js --min-templates 200 --min-evaluations 400 --min-readiness-score 90",
    "ops:suite": "node ./scripts/run-scheduler-suite.js",
    "ops:suite:heal": "node ./scripts/run-scheduler-suite.js --remediate-output-gates",
    "ops:suite:heal:owners": "node ./scripts/run-scheduler-suite.js --remediate-owner-mfa-memberships",
    "ops:suite:heal:all": "node ./scripts/run-scheduler-suite.js --remediate-output-gates --remediate-owner-mfa-memberships",
    "ops:suite:strict": "node ./scripts/run-scheduler-suite.js --fail-on-no-go",
    "ops:suite:local": "bash ./scripts/run-ops-suite-local.sh",
    "ops:suite:strict:local": "OPS_SUITE_LOCAL_STRICT=true bash ./scripts/run-ops-suite-local.sh",
    "ops:suite:strict:local:heal": "OPS_SUITE_LOCAL_STRICT=true OPS_SUITE_LOCAL_BACKFILL_RELEASE_REVIEWS=true OPS_SUITE_LOCAL_BACKFILL_REVIEW_RUNS=4 OPS_SUITE_LOCAL_WARMUP_REQUESTS=80 bash ./scripts/run-ops-suite-local.sh",
    "ops:suite:strict:heal": "node ./scripts/run-scheduler-suite.js --fail-on-no-go --remediate-output-gates",
    "ops:suite:strict:heal:all": "node ./scripts/run-scheduler-suite.js --fail-on-no-go --remediate-output-gates --remediate-owner-mfa-memberships",
    "owner:mfa:setup": "node ./scripts/setup-owner-mfa.js",
    "owner:mfa:remediate": "node ./scripts/remediate-owner-mfa-memberships.js",
    "report:scheduler:list": "node ./scripts/list-scheduler-reports.js",
    "report:scheduler:prune": "node ./scripts/prune-scheduler-reports.js --dry-run",
    "report:scheduler:prune:apply": "node ./scripts/prune-scheduler-reports.js --apply",
    "risk:goldset:generate": "node ./scripts/generate-risk-gold-set.js",
    "risk:goldset:report": "node ./scripts/risk-gold-set-report.js",
    "pilot:public": "bash ./scripts/public-pilot-run.sh",
    "pilot:public:heal": "bash ./scripts/public-pilot-run.sh --preflight-heal",
    "pilot:public:heal:all": "bash ./scripts/public-pilot-run.sh --preflight-heal-all",
    "git:check-large": "bash ./scripts/check-large-files.sh",
    "preflight:readiness:guard": "node ./scripts/check-public-readiness-guard.js",
    "preflight:pilot": "bash ./scripts/pilot-preflight.sh",
    "preflight:pilot:report": "ARCANA_PREFLIGHT_REPORT_FILE=./data/reports/preflight-latest.json bash ./scripts/pilot-preflight.sh",
    "preflight:pilot:advisor": "bash ./scripts/preflight-pilot-advisor.sh",
    "preflight:pilot:advisor:heal": "ARCANA_PREFLIGHT_USE_HEAL=true bash ./scripts/preflight-pilot-advisor.sh",
    "preflight:pilot:advisor:heal:all": "ARCANA_PREFLIGHT_USE_HEAL_ALL=true bash ./scripts/preflight-pilot-advisor.sh",
    "preflight:report:actions": "node ./scripts/preflight-report-actions.js",
    "preflight:report:actions:p0": "node ./scripts/preflight-report-actions.js --min-priority P0",
    "preflight:report:actions:p1": "node ./scripts/preflight-report-actions.js --min-priority P1",
    "preflight:pilot:heal": "ARCANA_PREFLIGHT_USE_HEAL=true bash ./scripts/pilot-preflight.sh",
    "preflight:pilot:heal:all": "ARCANA_PREFLIGHT_USE_HEAL_ALL=true bash ./scripts/pilot-preflight.sh",
    "design:colors": "node ./scripts/generate-admin-color-docs.js",
    "ingest:hairtpclinic": "node scripts/ingest-site.js --base https://www.hairtpclinic.se --out ./knowledge/hair-tp-clinic/site --sitemap --maxPages 120",
    "ingest:curatiio": "node scripts/ingest-site.js --base https://www.curatiio.se --out ./knowledge/curatiio/site --sitemap --maxPages 120",
    "lint:no-bypass": "node ./scripts/check-route-bypass.js && node ./scripts/check-cco-next-read-only.js",
    "audit:repair": "node ./scripts/audit-repair.js",
    "test": "npm run test:unit",
    "test:unit": "find ./tests -type f -name \"*.test.js\" -print0 | xargs -0 node --test",
    "ops:soak": "node ./scripts/run-load-soak.js",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.js",
    "test:a11y": "npx playwright test tests/a11y/",
    "test:load": "k6 run tests/load/k6-runtime-status.js",
    "test:mutation": "npx stryker run",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml,css,html}\"",
    "prepare": "husky || true",
    "i18n:extract": "node scripts/i18n-extract.js",
    "i18n:cleanup": "node scripts/i18n-cleanup.js",
    "i18n:merge": "node scripts/i18n-merge.js",
    "i18n:all": "npm run i18n:extract && npm run i18n:cleanup && npm run i18n:merge"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openai": "^6.22.0",
    "playwright": "1.58.2",
    "redis": "^4.7.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@axe-core/playwright": "^4.10.0",
    "@stryker-mutator/core": "^8.6.0",
    "axe-core": "^4.10.0",
    "eslint": "^9.13.0",
    "@eslint/js": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0"
  }
}
